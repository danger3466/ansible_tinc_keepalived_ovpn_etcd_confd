name: '{{ inventory_hostname }}'
data-dir: /var/lib/etcd

# Networking (Listening Interface vs Public Advertised Addresses)
listen-peer-urls: 'https://{{ ansible_facts['default_ipv4']['address'] }}:2380'
listen-client-urls: 'http://127.0.0.1:2379'
initial-advertise-peer-urls: 'https://{{ ansible_facts['default_ipv4']['address'] }}:2380'
#advertise-client-urls: 'https://10.10.0.11:2379'

# Cluster Topology Blueprint
initial-cluster: '{% for host in groups['all'] %}{{ (host + '=https://' + hostvars[host]['ansible_facts']['default_ipv4']['address'] + ':2380') }}{% if not loop.last %}, {% endif %}{% endfor %}'
initial-cluster-token: 'etcd-prod-token'
initial-cluster-state: 'new'
strict-reconfig-check: true

# Peer Security (Server-to-Server)
peer-transport-security:
  cert-file: '/etc/etcd/certs/peer.crt'
  key-file: '/etc/etcd/certs/peer.key'
  client-cert-auth: true
  trusted-ca-file: '/etc/etcd/certs/ca.crt'

# Performance & Retention Settings
heartbeat-interval: 250
election-timeout: 2000
auto-compaction-retention: '1'
quota-backend-bytes: 8589934592 # 8GB storage limit
